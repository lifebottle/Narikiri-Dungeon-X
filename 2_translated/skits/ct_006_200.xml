  <Strings>
    <Section>Story</Section>
    <Entry>
      <PointerOffset>38312</PointerOffset>
      <VoiceId>VCT_006_200_001</VoiceId>
      <JapaneseText>う〜〜〜〜〜ん……
………ん〜〜〜〜〜〜</JapaneseText>
      <EnglishText>Hmm...Hm....</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <BubbleId>1</BubbleId>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>39112</PointerOffset>
      <VoiceId>VCT_006_200_002</VoiceId>
      <JapaneseText>困っただぁ、あ〜、困っただ……
おらはどしたら、よかんべ？</JapaneseText>
      <EnglishText>Oh what trouble, what trouble~
What ever should I do!</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>2</Id>
      <BubbleId>1</BubbleId>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>40076</PointerOffset>
      <VoiceId>VCT_006_200_003</VoiceId>
      <JapaneseText>やっぱ選べねぇだ！　こっだら娘っ子揃ったら、
おら、ひとりに絞るのは難しいだ！</JapaneseText>
      <EnglishText>I really can't bring myself to choose 
amongst these lovely girls!</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <BubbleId>1</BubbleId>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>40604</PointerOffset>
      <VoiceId>VCT_006_200_004</VoiceId>
      <JapaneseText>&lt;Mel&gt;&lt;Mel&gt;が一番なのは当然だが、
&lt;Suzu&gt;ちんもなかなか捨てがたいだーな</JapaneseText>
      <EnglishText>&lt;Mel&gt; is naturally the best of amongst the bunch, but
&lt;Suzu&gt; is also hard to ignore.</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <BubbleId>1</BubbleId>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>41972</PointerOffset>
      <VoiceId>VCT_006_200_005</VoiceId>
      <JapaneseText>&lt;Rody&gt;たんもあのボディは群を抜いてるだが、
ミーたまもなかなかの物を持ってるだで</JapaneseText>
      <EnglishText>&lt;Rody&gt;'s figure makes her stand out amongst them, but
Mii also has some really good assets.</EnglishText>
      <Notes>ミー who</Notes>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <BubbleId>1</BubbleId>
      <Status>Problematic</Status>
    </Entry>
    <Entry>
      <PointerOffset>43312</PointerOffset>
      <VoiceId>VCT_006_200_006</VoiceId>
      <JapaneseText>いんや〜〜おら選べね！　誰かひとりにするなんて、
選ばれなかった娘っ子がかわいそうだーよ……</JapaneseText>
      <EnglishText>Oh my! I really can't choose! I feel so bad for the
girl that wouldn't get picked!</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <BubbleId>1</BubbleId>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>44144</PointerOffset>
      <VoiceId>VCT_006_200_007</VoiceId>
      <JapaneseText>ん？　まだ他にも娘っ子がいるっでが？
あー、ほうき女とエト助かい？</JapaneseText>
      <EnglishText>What, you say? There's more? 
A girl on a broomstick, and a healer?</EnglishText>
      <Notes>Context on エト助かい? I'm assuming it's mint</Notes>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <BubbleId>1</BubbleId>
      <Status>Problematic</Status>
    </Entry>
    <Entry>
      <PointerOffset>45360</PointerOffset>
      <VoiceId>VCT_006_200_008</VoiceId>
      <JapaneseText>ありゃボール球だ</JapaneseText>
      <EnglishText>Whoopie home run!</EnglishText>
      <Notes>Need context for tone</Notes>
      <SpeakerId>1</SpeakerId>
      <Id>8</Id>
      <BubbleId>1</BubbleId>
      <Status>Problematic</Status>
    </Entry>
  </Strings>
