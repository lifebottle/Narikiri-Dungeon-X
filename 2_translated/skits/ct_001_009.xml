  <Strings>
    <Section>Story</Section>
    <Entry>
      <PointerOffset>37340</PointerOffset>
      <VoiceId>&lt;VCT_001_009_001&gt;</VoiceId>
      <JapaneseText>さっき、もらった絵って、
&lt;ARC&gt;さんが描いたんですか？</JapaneseText>
      <EnglishText>The picture we received earlier, was it drawn by you, &lt;ARC&gt;?</EnglishText>
      <Notes/>
      <Id>1</Id>
      <StructId>1</StructId>
      <SpeakerId>1</SpeakerId>
      <UnknownPointer>13</UnknownPointer>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>37664</PointerOffset>
      <VoiceId>&lt;VCT_001_009_002&gt;</VoiceId>
      <JapaneseText>うん、そーだよ</JapaneseText>
      <EnglishText>Yeah, that's right.</EnglishText>
      <Notes/>
      <Id>2</Id>
      <StructId>2</StructId>
      <SpeakerId>2</SpeakerId>
      <UnknownPointer>15</UnknownPointer>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>37964</PointerOffset>
      <VoiceId>&lt;VCT_001_009_003&gt;</VoiceId>
      <JapaneseText>え！？　あのヘンテコヘタクソな絵、
&lt;ARC&gt;さんが……！？</JapaneseText>
      <EnglishText>What!? That weird, clumsy drawing was by you, &lt;ARC&gt;!?</EnglishText>
      <Notes/>
      <Id>3</Id>
      <StructId>3</StructId>
      <SpeakerId>3</SpeakerId>
      <UnknownPointer>12</UnknownPointer>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>38528</PointerOffset>
      <VoiceId>&lt;VCT_001_009_004&gt;</VoiceId>
      <JapaneseText>&lt;DIO&gt;！　そんなにはっきり言っちゃ……</JapaneseText>
      <EnglishText>&lt;DIO&gt;! You shouldn't say it so bluntly...</EnglishText>
      <Notes/>
      <Id>4</Id>
      <StructId>4</StructId>
      <SpeakerId>4</SpeakerId>
      <UnknownPointer>24</UnknownPointer>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>38852</PointerOffset>
      <VoiceId>&lt;VCT_001_009_005&gt;</VoiceId>
      <JapaneseText>ちっちっち、この絵のよさがわからないなんて
お子様だね</JapaneseText>
      <EnglishText>Tsk, tsk, tsk. Not understanding the charm of this drawing... you're such a child.</EnglishText>
      <Notes/>
      <Id>5</Id>
      <StructId>5</StructId>
      <SpeakerId>2</SpeakerId>
      <UnknownPointer>15</UnknownPointer>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>39788</PointerOffset>
      <VoiceId>&lt;VCT_001_009_006&gt;</VoiceId>
      <JapaneseText>子どもだもんな</JapaneseText>
      <EnglishText>Well, you are a child after all.</EnglishText>
      <Notes/>
      <Id>6</Id>
      <StructId>6</StructId>
      <SpeakerId>3</SpeakerId>
      <UnknownPointer>12</UnknownPointer>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>40060</PointerOffset>
      <VoiceId>&lt;VCT_001_009_007&gt;</VoiceId>
      <JapaneseText>わたしはわかるよ</JapaneseText>
      <EnglishText>I understand it.</EnglishText>
      <Notes/>
      <Id>7</Id>
      <StructId>7</StructId>
      <SpeakerId>1</SpeakerId>
      <UnknownPointer>13</UnknownPointer>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>40468</PointerOffset>
      <VoiceId>&lt;VCT_001_009_008&gt;</VoiceId>
      <JapaneseText>なっ……</JapaneseText>
      <EnglishText>Wha...?</EnglishText>
      <Notes/>
      <Id>8</Id>
      <StructId>8</StructId>
      <SpeakerId>3</SpeakerId>
      <UnknownPointer>12</UnknownPointer>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>40804</PointerOffset>
      <VoiceId>&lt;VCT_001_009_009&gt;</VoiceId>
      <JapaneseText>絵からほとばしる生命力や情熱を
いっぱい受け取って、背中がゾクゾクしました</JapaneseText>
      <EnglishText>I felt the vitality and passion radiating from the drawing, and it sent shivers down my spine.</EnglishText>
      <Notes/>
      <Id>9</Id>
      <StructId>9</StructId>
      <SpeakerId>1</SpeakerId>
      <UnknownPointer>13</UnknownPointer>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>41708</PointerOffset>
      <VoiceId>&lt;VCT_001_009_010&gt;</VoiceId>
      <JapaneseText>&lt;MEL&gt;ちゃん、大人♪</JapaneseText>
      <EnglishText>&lt;MEL&gt;, you're so mature♪</EnglishText>
      <Notes/>
      <Id>10</Id>
      <StructId>10</StructId>
      <SpeakerId>2</SpeakerId>
      <UnknownPointer>15</UnknownPointer>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>42348</PointerOffset>
      <VoiceId>&lt;VCT_001_009_011&gt;</VoiceId>
      <JapaneseText>……よくわかんねや</JapaneseText>
      <EnglishText>...I don't really get it.</EnglishText>
      <Notes/>
      <Id>11</Id>
      <StructId>11</StructId>
      <SpeakerId>3</SpeakerId>
      <UnknownPointer>12</UnknownPointer>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>42584</PointerOffset>
      <VoiceId>&lt;VCT_001_009_012&gt;</VoiceId>
      <JapaneseText>……ぼくもわからない……</JapaneseText>
      <EnglishText>...I don't understand either...</EnglishText>
      <Notes/>
      <Id>12</Id>
      <StructId>12</StructId>
      <SpeakerId>4</SpeakerId>
      <UnknownPointer>24</UnknownPointer>
      <Status>Proofreading</Status>
    </Entry>
