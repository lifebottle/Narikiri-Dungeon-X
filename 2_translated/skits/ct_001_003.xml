    <Entry>
      <PointerOffset>43176</PointerOffset>
      <VoiceId>&lt;VCT_001_003_007&gt;</VoiceId>
      <JapaneseText>うるせー！　タンス野郎は黙ってろ！！</JapaneseText>
      <EnglishText>Shut up! Keep quiet, you wardrobe freak!!</EnglishText>
