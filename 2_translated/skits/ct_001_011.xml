    <Entry>
      <PointerOffset>37208</PointerOffset>
      <VoiceId>&lt;VCT_001_011_001&gt;</VoiceId>
      <JapaneseText>&lt;DIO&gt;、初対面の人には
ちゃんと挨拶しなきゃ</JapaneseText>
      <EnglishText>&lt;DIO&gt;, you need to properly greet people when you meet them for the first time.</EnglishText>
      <Notes/>
      <Id>1</Id>
      <StructId>1</StructId>
      <SpeakerId>1</SpeakerId>
      <UnknownPointer>24</UnknownPointer>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>37516</PointerOffset>
      <VoiceId>&lt;VCT_001_011_002&gt;</VoiceId>
      <JapaneseText>え？　してるだろ？</JapaneseText>
      <EnglishText>Huh? I am, aren't I?</EnglishText>
      <Notes/>
      <Id>2</Id>
      <StructId>2</StructId>
      <SpeakerId>2</SpeakerId>
      <UnknownPointer>13</UnknownPointer>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>37812</PointerOffset>
      <VoiceId>&lt;VCT_001_011_003&gt;</VoiceId>
      <JapaneseText>してないよ</JapaneseText>
      <EnglishText>No, you're not.</EnglishText>
      <Notes/>
      <Id>3</Id>
      <StructId>3</StructId>
      <SpeakerId>3</SpeakerId>
      <UnknownPointer>13</UnknownPointer>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>37924</PointerOffset>
      <VoiceId>&lt;VCT_001_011_004&gt;</VoiceId>
      <JapaneseText>&lt;KLA&gt;さんとこでもさ……</JapaneseText>
      <EnglishText>Even at Dr. &lt;KLA&gt;'s place...</EnglishText>
      <Notes/>
      <Id>4</Id>
      <StructId>4</StructId>
      <SpeakerId>2</SpeakerId>
      <UnknownPointer>12</UnknownPointer>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>38036</PointerOffset>
      <VoiceId>&lt;VCT_001_011_005&gt;</VoiceId>
      <JapaneseText>ずっと&lt;MEL&gt;が&lt;KLA&gt;さんと
話してたよね</JapaneseText>
      <EnglishText>&lt;MEL&gt; was talking to Dr. &lt;KLA&gt; the whole time, right?</EnglishText>
      <Notes/>
      <Id>5</Id>
      <StructId>5</StructId>
      <SpeakerId>1</SpeakerId>
      <UnknownPointer>24</UnknownPointer>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>38336</PointerOffset>
      <VoiceId>&lt;VCT_001_011_006&gt;</VoiceId>
      <JapaneseText>さっき、&lt;KLA&gt;さんちの前で会った人にも
『あんた誰』とか言ってたし</JapaneseText>
      <EnglishText>And earlier, you said "Who are you?" to the person we met in front of Dr. &lt;KLA&gt;'s house.</EnglishText>
      <Notes/>
      <Id>6</Id>
      <StructId>6</StructId>
      <SpeakerId>3</SpeakerId>
      <UnknownPointer>13</UnknownPointer>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>38948</PointerOffset>
      <VoiceId>&lt;VCT_001_011_007&gt;</VoiceId>
      <JapaneseText>あ、あれは
怪しいヤツだったから……！</JapaneseText>
      <EnglishText>Th-that was because they seemed suspicious...!</EnglishText>
      <Notes/>
      <Id>7</Id>
      <StructId>7</StructId>
      <SpeakerId>2</SpeakerId>
      <UnknownPointer>12</UnknownPointer>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>39196</PointerOffset>
      <VoiceId>&lt;VCT_001_011_008&gt;</VoiceId>
      <JapaneseText>話をしないうちから、
怪しいとか決めつけないの</JapaneseText>
      <EnglishText>Don't decide someone is suspicious before even talking to them.</EnglishText>
      <Notes/>
      <Id>8</Id>
      <StructId>8</StructId>
      <SpeakerId>1</SpeakerId>
      <UnknownPointer>24</UnknownPointer>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>39572</PointerOffset>
      <VoiceId>&lt;VCT_001_011_009&gt;</VoiceId>
      <JapaneseText>…………</JapaneseText>
      <EnglishText>...</EnglishText>
      <Notes/>
      <Id>9</Id>
      <StructId>9</StructId>
      <SpeakerId>2</SpeakerId>
      <UnknownPointer>12</UnknownPointer>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>39880</PointerOffset>
      <VoiceId>&lt;VCT_001_011_010&gt;</VoiceId>
      <JapaneseText>なんで黙ってるの？</JapaneseText>
      <EnglishText>Why are you silent?</EnglishText>
      <Notes/>
      <Id>10</Id>
      <StructId>10</StructId>
      <SpeakerId>3</SpeakerId>
      <UnknownPointer>13</UnknownPointer>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>40112</PointerOffset>
      <VoiceId>&lt;VCT_001_011_011&gt;</VoiceId>
      <JapaneseText>なんでもねーよ</JapaneseText>
      <EnglishText>It's nothing.</EnglishText>
      <Notes/>
      <Id>11</Id>
      <StructId>11</StructId>
      <SpeakerId>2</SpeakerId>
      <UnknownPointer>12</UnknownPointer>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>40612</PointerOffset>
      <VoiceId>&lt;VCT_001_011_012&gt;</VoiceId>
      <JapaneseText>ヘンなの</JapaneseText>
      <EnglishText>That's weird.</EnglishText>
      <Notes/>
      <Id>12</Id>
      <StructId>12</StructId>
      <SpeakerId>3</SpeakerId>
      <UnknownPointer>13</UnknownPointer>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>41056</PointerOffset>
      <VoiceId>&lt;VCT_001_011_013&gt;</VoiceId>
      <JapaneseText>お年頃だね</JapaneseText>
      <EnglishText>It's that age, you know.</EnglishText>
      <Notes/>
      <Id>13</Id>
      <StructId>13</StructId>
      <SpeakerId>1</SpeakerId>
      <UnknownPointer>24</UnknownPointer>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>41224</PointerOffset>
      <VoiceId>&lt;VCT_001_011_014&gt;</VoiceId>
      <JapaneseText>…………？　そうなの？</JapaneseText>
      <EnglishText>...Really? Is that so?</EnglishText>
      <Notes/>
      <Id>14</Id>
      <StructId>14</StructId>
      <SpeakerId>3</SpeakerId>
      <UnknownPointer>13</UnknownPointer>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>41484</PointerOffset>
      <VoiceId>&lt;VCT_001_011_015&gt;</VoiceId>
      <JapaneseText>そういうお年頃</JapaneseText>
      <EnglishText>Yeah, that kind of age.</EnglishText>
      <Notes/>
      <Id>15</Id>
      <StructId>15</StructId>
      <SpeakerId>1</SpeakerId>
      <UnknownPointer>24</UnknownPointer>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>41784</PointerOffset>
      <VoiceId>&lt;VCT_001_011_016&gt;</VoiceId>
      <JapaneseText>ふーん……？</JapaneseText>
      <EnglishText>Hmm...?</EnglishText>
      <Notes/>
      <Id>16</Id>
      <StructId>16</StructId>
      <SpeakerId>3</SpeakerId>
      <UnknownPointer>13</UnknownPointer>
      <Status>Proofreading</Status>
    </Entry>
