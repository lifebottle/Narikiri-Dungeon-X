  <Strings>
    <Section>Story</Section>
    <Entry>
      <PointerOffset>37468</PointerOffset>
      <VoiceId>VCT_005_182_001</VoiceId>
      <JapaneseText>……&lt;Rody&gt;の料理の
味付けって、なんかなんかなんだよな……</JapaneseText>
      <EnglishText>&lt;Rody&gt;, your cooking tastes...
Uhm...something...something...</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <BubbleId>1</BubbleId>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>38060</PointerOffset>
      <VoiceId>VCT_005_182_002</VoiceId>
      <JapaneseText>何それ？　&lt;Dio&gt;くんの
お口には合わないってことかな？</JapaneseText>
      <EnglishText>Huh? &lt;Dio&gt; is it really that hard to 
put into words?</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <BubbleId>1</BubbleId>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>38520</PointerOffset>
      <VoiceId>VCT_005_182_003</VoiceId>
      <JapaneseText>合わないっていうか……
なぁ、&lt;Mel&gt;？</JapaneseText>
      <EnglishText>Rather than not put into words...
Uhh...&lt;Mel&gt;?</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <BubbleId>1</BubbleId>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>39056</PointerOffset>
      <VoiceId>VCT_005_182_004</VoiceId>
      <JapaneseText>え？　あぁ……えっと
美味しい……よ……？</JapaneseText>
      <EnglishText>Huh? Ahh...Uhm...
It's tasty...I guess...</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>4</Id>
      <BubbleId>1</BubbleId>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>39776</PointerOffset>
      <VoiceId>VCT_005_182_005</VoiceId>
      <JapaneseText>&lt;Mel&gt;ちゃんまで、奥歯に
ものがはさまったような言い方して</JapaneseText>
      <EnglishText>Even you, &lt;Mel&gt;? Did a cat got your
tongue too?</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>5</Id>
      <BubbleId>1</BubbleId>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>40140</PointerOffset>
      <VoiceId>VCT_005_182_006</VoiceId>
      <JapaneseText>何か一味足りてないっていうか……</JapaneseText>
      <EnglishText>It's something that's way more than a single taste...</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>6</Id>
      <BubbleId>1</BubbleId>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>40640</PointerOffset>
      <VoiceId>VCT_005_182_007</VoiceId>
      <JapaneseText>ビミョー？</JapaneseText>
      <EnglishText>Subtle?</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <BubbleId>1</BubbleId>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>41104</PointerOffset>
      <VoiceId>VCT_005_182_008</VoiceId>
      <JapaneseText>そう、微妙！</JapaneseText>
      <EnglishText>That's it! It's "subtle"!</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>8</Id>
      <BubbleId>1</BubbleId>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>41872</PointerOffset>
      <VoiceId>VCT_005_182_009</VoiceId>
      <JapaneseText>微妙！</JapaneseText>
      <EnglishText>Subtle!</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>9</Id>
      <BubbleId>1</BubbleId>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>42068</PointerOffset>
      <VoiceId>VCT_005_182_010</VoiceId>
      <JapaneseText>クリュ！</JapaneseText>
      <EnglishText>Coloor!</EnglishText>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>10</Id>
      <BubbleId>1</BubbleId>
      <Status>Problematic</Status>
    </Entry>
    <Entry>
      <PointerOffset>42324</PointerOffset>
      <VoiceId>VCT_005_182_011</VoiceId>
      <JapaneseText>微妙って……何？</JapaneseText>
      <EnglishText>What's...subtle?</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>11</Id>
      <BubbleId>1</BubbleId>
      <Status>Editing</Status>
    </Entry>
