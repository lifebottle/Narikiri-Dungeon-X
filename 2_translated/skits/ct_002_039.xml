    <Entry>
      <PointerOffset>42268</PointerOffset>
      <VoiceId>&lt;VCT_002_039_011&gt;</VoiceId>
      <JapaneseText>それできみは
何も食べなくて平気？</JapaneseText>
      <EnglishText>So, are you really okay not eating anything?</EnglishText>
      <Notes/>
      <Id>11</Id>
      <StructId>11</StructId>
      <SpeakerId>1</SpeakerId>
