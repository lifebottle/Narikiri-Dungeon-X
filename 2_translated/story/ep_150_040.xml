  <Strings>
    <Section>Story</Section>
    <Entry>
      <PointerOffset>258824</PointerOffset>
      <VoiceId>VSM_150_040_001</VoiceId>
      <JapaneseText>君たちは
マクスウェルのところへ
行くんだよね</JapaneseText>
      <EnglishText>So I assume you'll be leaving to
meet with Maxwell now, right? </EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>258964</PointerOffset>
      <VoiceId>VSM_150_040_002</VoiceId>
      <JapaneseText>そのことなんですけど……</JapaneseText>
      <EnglishText>That's what we normally would do, but...</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>258964</PointerOffset>
      <VoiceId>VSM_150_040_003</VoiceId>
      <JapaneseText>&lt;Dio&gt;、どうする？</JapaneseText>
      <EnglishText>&lt;Dio&gt;, what do you think we should do?</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <BubbleId>2</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>259348</PointerOffset>
      <VoiceId>VSM_150_040_004</VoiceId>
      <JapaneseText>…………</JapaneseText>
      <EnglishText>...</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>259840</PointerOffset>
      <VoiceId>VSM_150_040_005</VoiceId>
      <JapaneseText>&lt;Dio&gt;？　どうしたの？</JapaneseText>
      <EnglishText>&lt;Dio&gt;? What's on your mind?</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>4</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>260232</PointerOffset>
      <VoiceId>VSM_150_040_006</VoiceId>
      <JapaneseText>え……あ、え、何だよ？</JapaneseText>
      <EnglishText>Wh-What? What is it?</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>260484</PointerOffset>
      <VoiceId>VSM_150_040_007</VoiceId>
      <JapaneseText>……これから、
どうするかってこと</JapaneseText>
      <EnglishText>...We're asking you what we should do.</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>6</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>260624</PointerOffset>
      <VoiceId>VSM_150_040_008</VoiceId>
      <JapaneseText>どうするって……オレは
あのブレイナーって
のをなんとかしたい</JapaneseText>
      <EnglishText>Me? I think I'd like to go after Brainer.</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>7</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>260764</PointerOffset>
      <VoiceId>VSM_150_040_009</VoiceId>
      <JapaneseText>ブレイナーを？</JapaneseText>
      <EnglishText>Brainer, out of all people?</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>8</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>261132</PointerOffset>
      <VoiceId>VSM_150_040_010</VoiceId>
      <JapaneseText>……あ、あいつのせいで、
エレメンツポット
壊れたようなもんだろ</JapaneseText>
      <EnglishText>...W-Well, one way or another, it's
his fault the Elements' Pot broke!</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>9</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>261132</PointerOffset>
      <VoiceId>VSM_150_040_011</VoiceId>
      <JapaneseText>一発ぶん殴っとかないと、
気がすまないんだ</JapaneseText>
      <EnglishText>I need to beat his ass at least
once or else I won't feel satisfied.</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>9</Id>
      <BubbleId>2</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>261364</PointerOffset>
      <VoiceId>VSM_150_040_015</VoiceId>
      <JapaneseText>わたしもそっちに行くよ</JapaneseText>
      <EnglishText>Yeah, let me join you!</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>261364</PointerOffset>
      <VoiceId>VSM_150_040_016</VoiceId>
      <JapaneseText>言ったじゃない、
大変な状況になってるのに
放っておけないもん</JapaneseText>
      <EnglishText>I'm serious. This situation is too
dangerious to leave as is.</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <BubbleId>2</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>261700</PointerOffset>
      <VoiceId>VSM_150_040_017</VoiceId>
      <JapaneseText>力を貸してもらえるのは、
ありがたいけど……</JapaneseText>
      <EnglishText>I thank you very much
for offering, but...</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>11</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>262412</PointerOffset>
      <VoiceId>VSM_150_040_018</VoiceId>
      <JapaneseText>クルール！</JapaneseText>
      <EnglishText>Kuruuru!</EnglishText>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>12</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>262856</PointerOffset>
      <VoiceId>VSM_150_040_019</VoiceId>
      <JapaneseText>オレらだって……
&lt;Cless&gt;さんたちの力に
なりたいんだ</JapaneseText>
      <EnglishText>I want...to become your strength!</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>13</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>263052</PointerOffset>
      <VoiceId>VSM_150_040_020</VoiceId>
      <JapaneseText>うん</JapaneseText>
      <EnglishText>Me too!</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>14</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>263464</PointerOffset>
      <VoiceId>VSM_150_040_021</VoiceId>
      <JapaneseText>……そうか、わかった</JapaneseText>
      <EnglishText>All right, I get it.</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>15</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>263852</PointerOffset>
      <VoiceId>VSM_150_040_022</VoiceId>
      <JapaneseText>向かいましょう、
&lt;Red&gt;スルト深林&lt;White&gt;へ</JapaneseText>
      <EnglishText>Let's journey to the &lt;Red&gt;Deep
Forest Surt&lt;White&gt; together, then!</EnglishText>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>16</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
  </Strings>
</SceneText>
