    <Entry>
      <PointerOffset>264384</PointerOffset>
      <VoiceId>VSM_300_040_018</VoiceId>
      <JapaneseText>Sorcery  energy
density ninety-nine percent...</JapaneseText>
      <EnglishText>Sorcery energy density
ninety-nine percent...</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>17</Id>
      <BubbleId>2</BubbleId>
