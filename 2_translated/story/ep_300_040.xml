    </Entry>
    <Entry>
      <PointerOffset>264384</PointerOffset>
      <VoiceId>VSM_300_040_019</VoiceId>
      <JapaneseText>Laser operation system
all clear...</JapaneseText>
      <EnglishText>Laser operation system, all clear...</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>17</Id>
      <BubbleId>3</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>264384</PointerOffset>
      <VoiceId>VSM_300_040_020</VoiceId>
      <JapaneseText>All systems ready...</JapaneseText>
      <EnglishText>All systems, ready...</EnglishText>
      <Notes/>
